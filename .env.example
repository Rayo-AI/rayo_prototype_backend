# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rayo_finance?sslmode=disable

# JWT secret for signing tokens
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Server port
PORT=4000

NODE_ENV='development'
LOG_LEVEL='debug'

# Gemini API configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=your-gemini-api-url-here
GEMINI_API_NAME=your-gemini-api-name-here

# Email configuration
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SMTP_KEY=your-brevo-smtp-key-here

EMAIL_FROM=your-email-from-here
EMAIL_SUPPORT=your-support-email-here
APP_URL=http://localhost:4000

# Upstash Redis (Serverless caching)
# Get credentials from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry error monitoring
SENTRY_DSN=https://your-sentry-dsn-here.ingest.sentry.io/your-project-id

# Google OAuth configuration
# Get credentials from: https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback